{
  "name": "codebase-explainer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:backend": "tsx --watch src/server.ts",
    "dev:frontend": "vite",
    "build": "tsc && npm run build:frontend",
    "build:frontend": "vite build",
    "start": "node dist/src/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@octokit/rest": "^20.0.0",
    "madge": "^8.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "tsx": "^4.9.0",
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/madge": "^6.0.0",
    "concurrently": "^8.2.2",
    "vite": "^5.0.10",
    "@types/cors": "^2.8.5",
    "@types/axios": "^0.14.0"
  }
}