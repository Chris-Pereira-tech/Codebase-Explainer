{
  "name": "codebase-explainer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:backend": "tsx --env-file=.env.local --watch src/server.ts",
    "dev:frontend": "vite",
    "build": "tsc && npm run build:frontend",
    "build:frontend": "vite build",
    "start": "node dist/src/server.js"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.0",
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "madge": "^8.0.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.9.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
